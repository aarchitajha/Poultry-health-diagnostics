# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# React/Vite frontend (assuming build output might be in frontend/dist or dist)
dist/
dist-ssr/
*.local
frontend/dist/

# Flask/Static outputs (if needed, but usually we don't ignore static unless generated)
# model weights/metrics if large and not tracked
model/
!model/.gitkeep
# (assuming you want to ignore actual downloaded/trained models here, uncomment to enforce if needed)
# *.h5
# *.keras
# *.pt

# Dataset (if very large)
dataset/
!dataset/.gitkeep

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
